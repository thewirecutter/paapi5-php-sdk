{
    "name": "thewirecutter/paapi5-php-sdk",
    "description": "Amazon Creators API PHP SDK",
    "keywords": [
        "creatorsapi-php-sdk",
        "creatorsapi",
        "amazon",
        "creators-api"
    ],
    "homepage": "https://affiliate-program.amazon.com/creatorsapi",
    "license": "Apache-2.0",
    "authors": [
        {
            "name": "Amazon Creators",
            "homepage": "https://affiliate-program.amazon.com/creatorsapi"
        },
        {
            "name": "Justin Yost",
            "email": "justin.yost@wirecutter.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "guzzlehttp/guzzle": "^7.3",
        "guzzlehttp/psr7": "^1.7 || ^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0",
        "squizlabs/php_codesniffer": "^3.0",
        "friendsofphp/php-cs-fixer": "^3.5"
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "phpcs": "vendor/bin/phpcs --standard=phpcs.xml.dist -n examples src",
        "phpcbf": "vendor/bin/phpcbf --standard=phpcs.xml.dist -n examples src",
        "php-cs-fixer": "vendor/friendsofphp/php-cs-fixer/php-cs-fixer fix --allow-risky=yes --using-cache=no --config=.php_cs examples src/com/amazon/creators/auth/"
    },
    "autoload": {
        "psr-4": { "Amazon\\CreatorsAPI\\v1\\" : "src/" }
    },
    "autoload-dev": {
        "psr-4": { "Amazon\\CreatorsAPI\\v1\\Test\\" : "test/" }
    }
}
